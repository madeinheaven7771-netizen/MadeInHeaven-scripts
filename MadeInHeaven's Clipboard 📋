local function OpenColorPicker(colorKey, swatch)
    cpCurrentKey = colorKey
    local c = S[colorKey]
    cpCurrentR = math.floor(c.R * 255)
    cpCurrentG = math.floor(c.G * 255)
    cpCurrentB = math.floor(c.B * 255)
    cpInputs[1].Text = tostring(cpCurrentR)
    cpInputs[2].Text = tostring(cpCurrentG)
    cpInputs[3].Text = tostring(cpCurrentB)
    CPPreview.BackgroundColor3 = c
    CPLabel.Text = "R: "..cpCurrentR.."  G: "..cpCurrentG.."  B: "..cpCurrentB
    ColorPicker.Visible = true
end

for i, inp in ipairs(cpInputs) do
    inp:GetPropertyChangedSignal("Text"):Connect(function()
        local v = tonumber(inp.Text) or 0
        v = math.clamp(v, 0, 255)
        if i==1 then cpCurrentR=v elseif i==2 then cpCurrentG=v else cpCurrentB=v end
        local newColor = Color3.fromRGB(cpCurrentR, cpCurrentG, cpCurrentB)
        CPPreview.BackgroundColor3 = newColor
        CPLabel.Text = "R: "..cpCurrentR.."  G: "..cpCurrentG.."  B: "..cpCurrentB
    end)
end

CPApplyBtn.MouseButton1Click:Connect(function()
    if not cpCurrentKey then return end
    local newColor = Color3.fromRGB(cpCurrentR, cpCurrentG, cpCurrentB)
    S[cpCurrentKey] = newColor
    -- Update swatches
    if cpCurrentKey == "accentColor" then accentSwatch.BackgroundColor3 = newColor
    elseif cpCurrentKey == "bgColor" then bgSwatch.BackgroundColor3 = newColor
    elseif cpCurrentKey == "textColor" then textSwatch.BackgroundColor3 = newColor end
    -- Apply to UI
    MainFrame.BackgroundColor3 = S.bgColor
    Header.BackgroundColor3 = S.bgColor
    BottomBar.BackgroundColor3 = S.bgColor
    SaveData()
    ShowToast("🎨 Color updated!")
    ColorPicker.Visible = false
end)

