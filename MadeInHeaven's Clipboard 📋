local searchQuery = ""
local editingSlotData = nil   -- { tabIndex, slotIndex }
local tabButtons = {}
local slotFrames = {}

local function GetCurrentTab()
    return ClipboardData.tabs[ClipboardData.activeTabIndex]
end

local function GetSortedSlots(tab)
    local sorted = {}
    local query = searchQuery:lower()
    for i, slot in ipairs(tab.slots) do
        if query == "" or slot.name:lower():find(query, 1, true) or slot.content:lower():find(query, 1, true) then
            table.insert(sorted, { index = i, slot = slot })
        end
    end

    if S.sortMode == "A-Z" then
        table.sort(sorted, function(a, b) return a.slot.name:lower() < b.slot.name:lower() end)
    elseif S.sortMode == "Favorites" then
        table.sort(sorted, function(a, b)
            if a.slot.favorite == b.slot.favorite then return a.index < b.index end
            return (a.slot.favorite and 1 or 0) > (b.slot.favorite and 1 or 0)
        end)
    else -- Date (default, insertion order)
        -- already in insertion order
    end

    return sorted
end

-- ─── Render Tabs ───────────────────────────────────

local function RenderTabs()
    for _, btn in ipairs(tabButtons) do btn:Destroy() end
    tabButtons = {}

    local totalW = 0
    for i, tab in ipairs(ClipboardData.tabs) do
        local isActive = i == ClipboardData.activeTabIndex
        local btn = Create("TextButton", {
            Name = "Tab_"..i,
            Text = tab.name,
            Font = Enum.Font.GothamBold,
            TextSize = 12,
            TextColor3 = isActive and PALETTE.text or PALETTE.textLight,
            BackgroundColor3 = isActive and PALETTE.tabActive or PALETTE.tabBg,
            Size = UDim2.new(0, math.max(70, #tab.name * 8 + 24), 0, 30),
            LayoutOrder = i,
            ZIndex = 12,
            Parent = TabBarScroll,
        })
        RoundCorner(btn, 8)

        btn.MouseButton1Click:Connect(function()
            ClipboardData.activeTabIndex = i
            RenderTabs()
            RenderSlots()
        end)

        btn.MouseButton2Click:Connect(function()
            local mp = UserInputService:GetMouseLocation()
            ShowContext(mp, {
                { icon="✏️", label="Rename Tab", action=function()
                    ShowNameDialog("Rename Tab", "New tab name...", tab.name, function(newName)
                        ClipboardData.tabs[i].name = newName
                        RenderTabs()
                        SaveData()
                        ShowToast("✦ Tab renamed!")
                    end)
                end},
                { icon="🗑", label="Delete Tab", color=PALETTE.danger, action=function()
                    if #ClipboardData.tabs <= 1 then
                        ShowToast("⚠ Can't delete the last tab!", PALETTE.danger)
                        return
                    end
                    table.remove(ClipboardData.tabs, i)
                    if ClipboardData.activeTabIndex > #ClipboardData.tabs then
                        ClipboardData.activeTabIndex = #ClipboardData.tabs
                    end
                    RenderTabs()
                    RenderSlots()
                    SaveData()
                    ShowToast("🗑 Tab deleted!")
                end},
            })
        end)

        totalW = totalW + btn.AbsoluteSize.X + 6
        table.insert(tabButtons, btn)
    end

    task.defer(function()
        local tw = 0
        for _, btn in ipairs(tabButtons) do
            tw = tw + btn.AbsoluteSize.X + 6
        end
        TabBarScroll.CanvasSize = UDim2.new(0, tw + 4, 1, 0)
    end)
end

