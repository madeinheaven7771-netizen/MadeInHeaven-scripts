local function SafeJSON(t)
    local ok, result = pcall(function() return HttpService:JSONEncode(t) end)
    if ok then return result else return nil end
end

local function SaveData()
    if not writefile then return end
    local ok, encoded = pcall(function()
        local export = {
            tabs = {},
            settings = {
                accentColorR = ClipboardData.settings.accentColor.R,
                accentColorG = ClipboardData.settings.accentColor.G,
                accentColorB = ClipboardData.settings.accentColor.B,
                bgColorR = ClipboardData.settings.bgColor.R,
                bgColorG = ClipboardData.settings.bgColor.G,
                bgColorB = ClipboardData.settings.bgColor.B,
                textColorR = ClipboardData.settings.textColor.R,
                textColorG = ClipboardData.settings.textColor.G,
                textColorB = ClipboardData.settings.textColor.B,
                fontSize = ClipboardData.settings.fontSize,
                autoLoad = ClipboardData.settings.autoLoad,
                sortMode = ClipboardData.settings.sortMode,
            },
            activeTabIndex = ClipboardData.activeTabIndex,
        }
        for _, tab in ipairs(ClipboardData.tabs) do
            local t = { name = tab.name, slots = {} }
            for _, slot in ipairs(tab.slots) do
                table.insert(t.slots, {
                    name = slot.name,
                    content = slot.content,
                    locked = slot.locked,
                    favorite = slot.favorite,
                    created = slot.created,
                })
            end
            table.insert(export.tabs, t)
        end
        return HttpService:JSONEncode(export)
    end)
    if ok then
        pcall(function() writefile("MIH_Clipboard.json", encoded) end)
    end
end

local function LoadData()
    if not readfile then return end
    local ok, raw = pcall(function() return readfile("MIH_Clipboard.json") end)
    if not ok or not raw or raw == "" then return end
    local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not ok2 or not data then return end

    pcall(function()
        if data.tabs then
            ClipboardData.tabs = {}
            for _, tab in ipairs(data.tabs) do
                local t = { name = tab.name or "Tab", slots = {} }
                for _, slot in ipairs(tab.slots or {}) do
                    table.insert(t.slots, {
                        name = slot.name or "Slot",
                        content = slot.content or "",
                        locked = slot.locked or false,
                        favorite = slot.favorite or false,
                        created = slot.created or os.time(),
                    })
                end
                table.insert(ClipboardData.tabs, t)
            end
        end
        if data.settings then
            local s = data.settings
            if s.accentColorR then ClipboardData.settings.accentColor = Color3.new(s.accentColorR, s.accentColorG, s.accentColorB) end
            if s.bgColorR then ClipboardData.settings.bgColor = Color3.new(s.bgColorR, s.bgColorG, s.bgColorB) end
            if s.textColorR then ClipboardData.settings.textColor = Color3.new(s.textColorR, s.textColorG, s.textColorB) end
            if s.fontSize then ClipboardData.settings.fontSize = s.fontSize end
            if s.autoLoad ~= nil then ClipboardData.settings.autoLoad = s.autoLoad end
            if s.sortMode then ClipboardData.settings.sortMode = s.sortMode end
        end
        if data.activeTabIndex then ClipboardData.activeTabIndex = data.activeTabIndex end
    end)
end

LoadData()

