local function OpenEditModal(tabIdx, slotIdx)
    local tab = ClipboardData.tabs[tabIdx]
    local slot = tab and tab.slots[slotIdx]
    editingSlotData = { tabIndex = tabIdx, slotIndex = slotIdx }

    ModalTitle.Text = slotIdx and "✏  Edit Slot" or "✦  New Slot"
    ModalNameBox.Text = slot and slot.name or ("Slot " .. ((#tab.slots) + 1))
    ModalContentBox.Text = slot and slot.content or ""
    ModalCharCount.Text = string.len(ModalContentBox.Text) .. " chars"

    Overlay.Visible = true
    Overlay.BackgroundTransparency = 0.6
    Modal.Visible = true
    Modal.Size = UDim2.new(0, 420, 0, 0)
    Tween(Modal, { Size = UDim2.new(0, 420, 0, 320) }, 0.25)
    task.defer(function() ModalContentBox:CaptureFocus() end)
end

local function CloseModal()
    Tween(Modal, { Size = UDim2.new(0, 420, 0, 0) }, 0.2)
    task.delay(0.22, function()
        Modal.Visible = false
        Overlay.Visible = false
        editingSlotData = nil
    end)
end

local function RenderSlots()
    -- Clear existing
    for _, f in ipairs(slotFrames) do f:Destroy() end
    slotFrames = {}

    local tab = GetCurrentTab()
    if not tab then return end

    local sorted = GetSortedSlots(tab)
    SlotCountLabel.Text = #tab.slots .. " / 1000 slots"

    for order, entry in ipairs(sorted) do
        local i = entry.index
        local slot = entry.slot

        local slotH = 62
        local slotFrame = Create("Frame", {
            Name = "Slot_"..i,
            Size = UDim2.new(1, -4, 0, slotH),
            BackgroundColor3 = slot.favorite and C(255, 248, 200) or PALETTE.slot,
            BorderSizePixel = 0,
            LayoutOrder = order,
            ZIndex = 12,
            Parent = SlotsScroll,
        })
        RoundCorner(slotFrame, 10)

        -- Left accent bar
        local accentBar = Create("Frame", {
            Size = UDim2.new(0, 4, 1, -12),
            Position = UDim2.new(0, 0, 0, 6),
            BackgroundColor3 = slot.favorite and PALETTE.fav or PALETTE.accent,
            BorderSizePixel = 0,
            ZIndex = 13,
            Parent = slotFrame,
        })
        RoundCorner(accentBar, 2)

        -- Slot name
        local nameLabel = Create("TextLabel", {
            Text = (slot.locked and "🔒 " or "") .. (slot.favorite and "⭐ " or "") .. slot.name,
            Font = Enum.Font.GothamBold,
            TextSize = 13,
            TextColor3 = PALETTE.text,
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 14, 0, 8),
            Size = UDim2.new(0.7, -14, 0, 18),
            TextXAlignment = Enum.TextXAlignment.Left,
            TextTruncate = Enum.TextTruncate.AtEnd,
            ZIndex = 13,
            Parent = slotFrame,
        })
        nameLabel.TextSize = S.fontSize

        -- Slot preview
        local previewLabel = Create("TextLabel", {
            Text = slot.content == "" and "(empty)" or slot.content,
            Font = Enum.Font.Gotham,
            TextSize = 11,
            TextColor3 = slot.content == "" and PALETTE.textLight or PALETTE.text,
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 14, 0, 30),
            Size = UDim2.new(1, -90, 0, 18),
            TextXAlignment = Enum.TextXAlignment.Left,
            TextTruncate = Enum.TextTruncate.AtEnd,
            ZIndex = 13,
            Parent = slotFrame,
        })

        -- Copy button
        local copyBtn = Create("TextButton", {
            Text = "📋",
            Font = Enum.Font.GothamBold, TextSize = 14,
            TextColor3 = PALETTE.textLight, BackgroundColor3 = PALETTE.panel,
            Size = UDim2.new(0, 30, 0, 30),
            Position = UDim2.new(1, -98, 0.5, -15),
            ZIndex = 14, Parent = slotFrame,
        })
        RoundCorner(copyBtn, 7)

        -- Edit button
        local editBtn = Create("TextButton", {
            Text = "✏",
            Font = Enum.Font.GothamBold, TextSize = 14,
            TextColor3 = PALETTE.text, BackgroundColor3 = PALETTE.accent,
            Size = UDim2.new(0, 30, 0, 30),
            Position = UDim2.new(1, -62, 0.5, -15),
            ZIndex = 14, Parent = slotFrame,
        })
        RoundCorner(editBtn, 7)

        -- Delete button
        local delBtn = Create("TextButton", {
            Text = "✕",
            Font = Enum.Font.GothamBold, TextSize = 12,
            TextColor3 = PALETTE.white, BackgroundColor3 = PALETTE.danger,
            Size = UDim2.new(0, 26, 0, 26),
            Position = UDim2.new(1, -30, 0.5, -13),
            ZIndex = 14, Parent = slotFrame,
        })
        RoundCorner(delBtn, 7)

        -- Hover effects
        slotFrame.MouseEnter:Connect(function()
            Tween(slotFrame, { BackgroundColor3 = PALETTE.slotHover }, 0.12)
        end)
        slotFrame.MouseLeave:Connect(function()
            Tween(slotFrame, { BackgroundColor3 = slot.favorite and C(255,248,200) or PALETTE.slot }, 0.12)
        end)

        -- Copy
        copyBtn.MouseButton1Click:Connect(function()
            if setclipboard then
                setclipboard(slot.content)
                ShowToast("📋 Copied to clipboard!", PALETTE.success)
            else
                ShowToast("⚠ setclipboard not available", PALETTE.danger)
            end
        end)

        -- Edit
        editBtn.MouseButton1Click:Connect(function()
            if slot.locked then
                ShowToast("🔒 This slot is locked!", PALETTE.lock)
                return
            end
            OpenEditModal(ClipboardData.activeTabIndex, i)
        end)

        -- Delete
        delBtn.MouseButton1Click:Connect(function()
            if slot.locked then
                ShowToast("🔒 Slot is locked!", PALETTE.lock)
                return
            end
            table.remove(ClipboardData.tabs[ClipboardData.activeTabIndex].slots, i)
            SaveData()
            RenderSlots()
            ShowToast("🗑 Slot deleted!")
        end)

        -- Right click context menu
        slotFrame.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton2 then
                local mp = UserInputService:GetMouseLocation()
                ShowContext(mp, {
                    { icon="✏️", label="Edit", action=function()
                        if slot.locked then ShowToast("🔒 Slot is locked!", PALETTE.lock) return end
                        OpenEditModal(ClipboardData.activeTabIndex, i)
                    end},
                    { icon="📋", label="Copy Content", action=function()
                        if setclipboard then setclipboard(slot.content) ShowToast("📋 Copied!",PALETTE.success) end
                    end},
                    { icon=slot.favorite and "⭐" or "☆", label=slot.favorite and "Unfavorite" or "Favorite", action=function()
                        slot.favorite = not slot.favorite
                        SaveData(); RenderSlots()
                        ShowToast(slot.favorite and "⭐ Added to favorites!" or "☆ Removed from favorites!")
                    end},
                    { icon=slot.locked and "🔓" or "🔒", label=slot.locked and "Unlock" or "Lock", action=function()
                        slot.locked = not slot.locked
                        SaveData(); RenderSlots()
                        ShowToast(slot.locked and "🔒 Slot locked!" or "🔓 Slot unlocked!")
                    end},
                    { icon="📄", label="Duplicate", action=function()
                        local tab2 = ClipboardData.tabs[ClipboardData.activeTabIndex]
                        if #tab2.slots >= 1000 then ShowToast("⚠ 1000 slot limit reached!", PALETTE.danger) return end
                        local dup = { name=slot.name.." (copy)", content=slot.content, locked=false, favorite=false, created=os.time() }
                        table.insert(tab2.slots, i+1, dup)
                        SaveData(); RenderSlots()
                        ShowToast("📄 Slot duplicated!")
                    end},
                    { icon="🔤", label="Rename", action=function()
                        ShowNameDialog("Rename Slot", "New name...", slot.name, function(newName)
                            slot.name = newName
                            SaveData(); RenderSlots()
                            ShowToast("✏ Slot renamed!")
                        end)
                    end},
                    { icon="🗑", label="Delete", color=PALETTE.danger, action=function()
                        if slot.locked then ShowToast("🔒 Slot is locked!", PALETTE.lock) return end
                        table.remove(ClipboardData.tabs[ClipboardData.activeTabIndex].slots, i)
                        SaveData(); RenderSlots()
                        ShowToast("🗑 Slot deleted!")
                    end},
                })
            end
        end)

        table.insert(slotFrames, slotFrame)
    end

    -- Update scroll canvas
    task.defer(function()
        local h = SlotsLayout.AbsoluteContentSize.Y
        SlotsScroll.CanvasSize = UDim2.new(0, 0, 0, h + 8)
    end)
end

